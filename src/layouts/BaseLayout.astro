---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
// Self-hosted fonts (no external requests — DSGVO-friendly, no Google CDN)
import '@fontsource-variable/newsreader/opsz.css';
import '@fontsource-variable/newsreader/opsz-italic.css';
import '@fontsource/ibm-plex-mono/400.css';
import '@fontsource/ibm-plex-mono/500.css';
import '@fontsource/ibm-plex-mono/600.css';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}
const { title, description = "Nils Hillmann's DFIR portfolio blog — learning digital forensics in public." } = Astro.props;
const currentPath = Astro.url.pathname;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="apple-touch-icon" href="/logo.png" />
    <script is:inline src="/theme-init.js"></script>
  </head>
  <body>
    <Header currentPath={currentPath} />
    <main><slot /></main>
    <Footer />
    <script>
      import '../scripts/theme-toggle';
    </script>
  </body>
</html>
