---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const toolsRaw = await getCollection('tools');
const radar = (await getCollection('radar'))
  .sort((a, b) => a.data.order - b.data.order);

type DomainId = 'android' | 'windows' | 'network' | 'memory';
type Diff = 'easy' | 'medium' | 'hard' | 'lab' | 'in progress';

const DOMAINS: { id: DomainId; label: string; blurb: string }[] = [
  { id: 'android', label: 'ANDROID', blurb: 'app data, artifacts, extractions' },
  { id: 'windows', label: 'WINDOWS', blurb: 'disk, registry, endpoint triage' },
  { id: 'network', label: 'NETWORK', blurb: 'pcaps, protocols, traffic analysis' },
  { id: 'memory',  label: 'MEMORY',  blurb: 'RAM captures, volatile evidence' }
];

const TIER: Record<number, { label: string; cls: string }> = {
  3: { label: 'WORKING PROFICIENCY', cls: 'tier-3' },
  2: { label: 'HANDS-ON, LEARNING',  cls: 'tier-2' },
  1: { label: 'EXPLORED',            cls: 'tier-1' }
};

const diffRank: Record<Diff, number> = { hard: 0, medium: 1, easy: 2, lab: 3, 'in progress': 4 };
const RECEIPT_CAP = 3;

// tools sorted by tier, then by amount of evidence
const tools = toolsRaw.sort((a, b) =>
  b.data.tier - a.data.tier || b.data.challenges.length - a.data.challenges.length
);

function countsLine(challenges: { difficulty: Diff }[]): string {
  const n = challenges.length;
  const hard = challenges.filter(c => c.difficulty === 'hard').length;
  const med = challenges.filter(c => c.difficulty === 'medium').length;
  let line = `${n} ${n === 1 ? 'lab' : 'labs'}`;
  if (hard > 0) line += ` · ${hard} hard`;
  else if (med > 0) line += ` · ${med} medium`;
  return line;
}

const domainSections = DOMAINS.map((d, i) => {
  const dTools = tools.filter(t => t.data.domains.includes(d.id));
  const labs = dTools.reduce((s, t) => s + t.data.challenges.length, 0);
  const hard = dTools.reduce((s, t) => s + t.data.challenges.filter(c => c.difficulty === 'hard').length, 0);
  let agg = `${labs} labs`;
  if (hard > 0) agg += ` · ${hard} hard`;
  agg += ` · ${dTools.length} ${dTools.length === 1 ? 'tool' : 'tools'}`;
  return { ...d, num: '0' + (i + 1), tools: dTools, agg };
}).filter(s => s.tools.length > 0);

const FILTERS = [
  { id: 'all', label: 'ALL DOMAINS', count: tools.length },
  ...DOMAINS.map(d => ({
    id: d.id, label: d.label,
    count: tools.filter(t => t.data.domains.includes(d.id)).length
  }))
];

const domainLabel: Record<DomainId, string> = Object.fromEntries(
  DOMAINS.map(d => [d.id, d.label])
) as Record<DomainId, string>;

function sortedReceipts(challenges: { name: string; platform: string; difficulty: Diff; url?: string }[]) {
  return [...challenges].sort((a, b) => diffRank[a.difficulty] - diffRank[b.difficulty]);
}

function receiptTitle(c: { name: string; platform: string; difficulty: Diff }): string {
  const provider = c.platform === 'THM' ? 'TryHackMe' : c.platform === 'CD' ? 'CyberDefenders' : 'own lab';
  return c.platform === 'own lab' ? `${c.name} — ${provider}` : `${c.name} — ${provider} (${c.difficulty})`;
}

function diffClass(d: Diff): string {
  if (d === 'medium' || d === 'in progress' || d === 'lab') return 'd-med';
  return `d-${d}`;
}
---
<BaseLayout title="Toolbox — dfir.89deg.com">

  <section class="page-head container">
    <p class="kicker">// TOOLBOX — BY DOMAIN</p>
    <h1>Screwdrivers, flux capacitors &amp; other precision instruments.</h1>
    <p class="lede">The workbench, sorted by what I investigate — not just what I run. Each tool carries an honest, job-anchored level and the completed labs behind it — difficulty rated by the platform, not by me. Click any receipt to check it.</p>
    <div class="legend">
      <span class="lg-label">LEVEL:</span>
      <span><span class="lg seg-3">▮▮▮</span> working proficiency</span>
      <span><span class="lg seg-2">▮▮</span> hands-on, learning</span>
      <span><span class="lg seg-1">▮</span> explored</span>
      <span class="lg-sep" aria-hidden="true"></span>
      <span><span class="lg d-hard">hard</span> · <span class="lg d-med">medium</span> · <span class="lg d-easy">easy</span> · <span class="lg d-med">lab</span> = own case</span>
    </div>
  </section>

  <section class="container tabs-section">
    <div class="tabs" role="tablist" aria-label="Filter by domain">
      {FILTERS.map(f => (
        <button
          class={f.id === 'all' ? 'tab active' : 'tab'}
          data-filter={f.id}
        >{f.label} <span class="tab-count">({f.count})</span></button>
      ))}
    </div>
  </section>

  <section class="container inventory">
    {domainSections.map(sec => (
      <div class="domain" data-domain={sec.id}>
        <div class="domain-head">
          <div class="domain-title">
            <span class="domain-num">{sec.num}</span>
            <h2>{sec.label} FORENSICS</h2>
            <span class="domain-blurb">{sec.blurb}</span>
          </div>
          <div class="domain-agg">
            <span class="agg-label">DOMAIN EVIDENCE</span>
            <span class="agg-value">{sec.agg}</span>
          </div>
        </div>

        {sec.tools.map(t => {
          const receipts = sortedReceipts(t.data.challenges);
          const extra = receipts.length - RECEIPT_CAP;
          const tier = TIER[t.data.tier];
          return (
            <div class="tool-row">
              <div class="tool-main">
                <a href={t.data.url} target="_blank" rel="noopener" class="tool-name">{t.data.name}</a>
                <p class="tool-desc">{t.data.desc}</p>
                <p class="tool-verdict">“{t.data.verdict}”</p>
                <a href={t.data.url} target="_blank" rel="noopener" class="tool-link">{t.data.linkLabel} →</a>
                <div class="tool-tags">
                  {t.data.domains.map(d => (
                    <button class="tag" data-goto={d} title="Show this domain">{domainLabel[d as DomainId]}</button>
                  ))}
                </div>
              </div>
              <div class="tool-evidence">
                <div class="evidence-head">
                  <div class="tier">
                    <span class="tier-segs" aria-hidden="true">
                      {[1, 2, 3].map(i => (
                        <span class={i <= t.data.tier ? `seg on ${tier.cls}` : 'seg'}></span>
                      ))}
                    </span>
                    <span class={`tier-label ${tier.cls}`}>{tier.label}</span>
                  </div>
                  <span class="counts">{countsLine(t.data.challenges)}</span>
                </div>
                <div class="receipts">
                  {receipts.map((c, i) => (
                    <a
                      href={c.url ?? '#'}
                      target="_blank"
                      rel="noopener"
                      class={i >= RECEIPT_CAP ? 'receipt hidden-receipt' : 'receipt'}
                      title={receiptTitle(c)}
                    >
                      <span class={`diff ${diffClass(c.difficulty)}`}>{c.difficulty === 'in progress' ? 'wip' : c.difficulty}</span>
                      {c.name}
                    </a>
                  ))}
                  {extra > 0 && (
                    <button class="more" data-more={`+${extra} more`}>+{extra} more</button>
                  )}
                </div>
              </div>
            </div>
          );
        })}
      </div>
    ))}
  </section>

  {radar.length > 0 && (
    <section class="container radar-section">
      <div class="radar-head">
        <h2>ON THE RADAR</h2>
        <span class="radar-note">no receipts yet — and I’ll say so</span>
      </div>
      <div class="radar-grid">
        {radar.map(r => (
          <div class="radar-card">
            <span class="radar-name">{r.data.name}</span>
            <span class="radar-why">{r.data.why}</span>
          </div>
        ))}
      </div>
    </section>
  )}

</BaseLayout>

<script>
  // domain tab filter
  const tabs = document.querySelectorAll<HTMLButtonElement>('.tab');
  const domains = document.querySelectorAll<HTMLElement>('.domain');
  function applyFilter(id: string) {
    tabs.forEach(t => t.classList.toggle('active', t.dataset.filter === id));
    domains.forEach(d => {
      d.style.display = id === 'all' || d.dataset.domain === id ? '' : 'none';
    });
  }
  tabs.forEach(t => t.addEventListener('click', () => applyFilter(t.dataset.filter!)));
  // domain tag chips jump to their domain filter
  document.querySelectorAll<HTMLButtonElement>('.tag').forEach(tag => {
    tag.addEventListener('click', () => {
      applyFilter(tag.dataset.goto!);
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  });
  // expand/collapse receipts beyond the cap
  document.querySelectorAll<HTMLButtonElement>('.more').forEach(btn => {
    btn.addEventListener('click', () => {
      const open = btn.classList.toggle('open');
      btn.closest('.receipts')!.querySelectorAll('.hidden-receipt').forEach(r =>
        r.classList.toggle('shown', open)
      );
      btn.textContent = open ? 'show less' : btn.dataset.more!;
    });
  });
</script>

<style>
  .page-head { padding-top: 72px; }
  h1 {
    margin: 0;
    font-size: clamp(34px, 7.5vw, 56px);
    line-height: 1.08;
    font-weight: 500;
    letter-spacing: -0.015em;
    max-width: 20ch;
    text-wrap: balance;
  }
  .lede {
    margin: 22px 0 0 0;
    font-size: 20px;
    line-height: 1.55;
    color: var(--dim);
    font-style: italic;
    max-width: 60ch;
    text-wrap: pretty;
  }

  /* legend */
  .legend {
    margin-top: 36px;
    border: 1px solid var(--hairline);
    background: var(--soft);
    padding: 16px 22px;
    display: flex;
    gap: 12px 26px;
    flex-wrap: wrap;
    align-items: center;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 12px;
    color: var(--muted);
  }
  .lg { font-weight: 600; }
  .lg-label { color: var(--faint); }
  .lg-sep { width: 1px; height: 14px; background: var(--sep); }
  .seg-3 { color: var(--accent); }
  .seg-2 { color: var(--dim); }
  .seg-1 { color: var(--faint); }
  .d-hard { color: var(--hard); }
  .d-med { color: var(--med); }
  .d-easy { color: var(--easy); }

  /* tabs */
  .tabs-section { padding-top: 44px; }
  .tabs {
    display: flex;
    flex-wrap: wrap;
    gap: 0 4px;
    border-bottom: 1px solid var(--ink);
  }
  .tab {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    background: transparent;
    color: var(--muted);
    border: none;
    border-bottom: 2px solid transparent;
    padding: 10px 16px 9px 16px;
    cursor: pointer;
  }
  .tab:hover { color: var(--accent); }
  .tab.active {
    color: var(--accent);
    border-bottom-color: var(--accent);
    background: var(--soft);
  }
  .tab-count { font-weight: 400; opacity: 0.65; }

  /* domain sections */
  .domain { padding-top: 52px; }
  .domain-head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 12px 40px;
    align-items: end;
    border-bottom: 1px solid var(--ink);
    padding-bottom: 12px;
  }
  .domain-title {
    display: flex;
    align-items: baseline;
    gap: 16px;
    flex-wrap: wrap;
  }
  .domain-num {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 12px;
    font-weight: 600;
    color: var(--accent);
  }
  .domain-title h2 {
    margin: 0;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.12em;
  }
  .domain-blurb {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    color: var(--faint);
  }
  .domain-agg {
    display: flex;
    align-items: baseline;
    gap: 10px;
    font-family: 'IBM Plex Mono', monospace;
  }
  .agg-label { font-size: 10.5px; letter-spacing: 0.1em; color: var(--faint); }
  .agg-value { font-size: 13px; font-weight: 600; color: var(--ink); }

  /* tool rows */
  .tool-row {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(0, 1fr);
    gap: 16px 40px;
    padding: 30px 0;
    border-bottom: 1px solid var(--hairline2);
    align-items: start;
  }
  .tool-main { display: flex; flex-direction: column; gap: 8px; }
  .tool-name {
    font-size: 26px;
    font-weight: 500;
    color: var(--ink);
    text-decoration: none;
    line-height: 1.2;
  }
  .tool-name:hover { color: var(--accent); }
  .tool-desc {
    margin: 0;
    font-size: 16.5px;
    line-height: 1.55;
    color: var(--dim);
    text-wrap: pretty;
  }
  .tool-verdict {
    margin: 0;
    font-size: 14.5px;
    font-style: italic;
    line-height: 1.5;
    color: var(--muted);
    text-wrap: pretty;
  }
  .tool-link {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11.5px;
    color: var(--accent);
    text-decoration: none;
    margin-top: 2px;
  }
  .tool-link:hover { text-decoration: underline; }
  .tool-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 6px; }
  .tag {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.08em;
    color: var(--muted);
    background: var(--soft);
    border: 1px solid var(--hairline);
    padding: 3px 8px;
    cursor: pointer;
  }
  .tag:hover { color: var(--accent); border-color: var(--accent-bd); }

  /* evidence column */
  .tool-evidence { display: flex; flex-direction: column; gap: 12px; padding-top: 4px; }
  .evidence-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }
  .tier { display: flex; align-items: center; gap: 9px; }
  .tier-segs { display: flex; gap: 3px; }
  .seg { width: 17px; height: 6px; background: var(--offcell); }
  .seg.on.tier-3 { background: var(--accent); }
  .seg.on.tier-2 { background: var(--dim); }
  .seg.on.tier-1 { background: var(--faint); }
  .tier-label {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.04em;
  }
  .tier-label.tier-3 { color: var(--accent); }
  .tier-label.tier-2 { color: var(--dim); }
  .tier-label.tier-1 { color: var(--faint); }
  .counts {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    color: var(--faint);
    white-space: nowrap;
  }

  /* receipts */
  .receipts { display: flex; flex-wrap: wrap; gap: 6px; align-items: center; }
  .receipt {
    display: inline-flex;
    align-items: baseline;
    gap: 7px;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11.5px;
    color: var(--body);
    background: var(--soft);
    border: 1px solid var(--hairline);
    padding: 4px 9px;
    text-decoration: none;
  }
  .receipt:hover { border-color: var(--accent-bd); color: var(--accent); }
  .receipt .diff { font-weight: 600; letter-spacing: 0.04em; }
  .hidden-receipt { display: none; }
  .hidden-receipt.shown { display: inline-flex; }
  .more {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11.5px;
    font-weight: 600;
    color: var(--accent);
    background: transparent;
    border: none;
    padding: 4px 4px;
    cursor: pointer;
  }
  .more:hover { text-decoration: underline; }

  /* radar */
  .radar-section { padding-top: 64px; padding-bottom: 84px; }
  .radar-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    border-bottom: 1px solid var(--ink);
    padding-bottom: 12px;
  }
  .radar-head h2 {
    margin: 0;
    font-size: 15px;
    font-weight: 600;
    font-family: 'IBM Plex Mono', monospace;
    letter-spacing: 0.1em;
  }
  .radar-note {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 12px;
    color: var(--faint);
  }
  .radar-grid { display: flex; gap: 14px; flex-wrap: wrap; padding-top: 22px; }
  .radar-card {
    border: 1px solid var(--hairline);
    background: var(--card);
    padding: 14px 18px;
    display: flex;
    flex-direction: column;
    gap: 5px;
  }
  .radar-name { font-size: 18px; font-weight: 500; }
  .radar-why {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    color: var(--faint);
  }

  @media (max-width: 760px) {
    .domain-head, .tool-row { grid-template-columns: 1fr; gap: 16px; }
  }
</style>
